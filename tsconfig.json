{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": false,
    "noEmit": true,
    "types": ["react", "react-dom"]
  },
  "//": "allowJs:false makes tsc resolve each component import to its sibling .d.ts (not the .jsx), so the hand-written prop contracts become the package's public types.",
  "include": ["src", "components/**/*.d.ts", "tests/types"]
}
