{
  "name": "twico-ui",
  "version": "0.1.0",
  "description": "Twico UI — a free, modern, themeable React + Tailwind-friendly component library. 53 components with dark mode, motion, and accessibility built in.",
  "license": "MIT",
  "author": "Twico UI",
  "homepage": "https://github.com/EncryptionL/twico-ui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/EncryptionL/twico-ui.git"
  },
  "bugs": {
    "url": "https://github.com/EncryptionL/twico-ui/issues"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "component-library",
    "design-system",
    "tailwind",
    "dark-mode",
    "accessible",
    "datatable",
    "twico",
    "twico-ui"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./styles/twico-ui.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "styles",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
